# Next.js dev/start port — chosen to avoid collisions with common 3000/3001
PORT=3871

# URL the agent uses to call back into the app (defaults to http://localhost:$PORT)
# REVIEWER_API_URL=http://localhost:3871

# Claude Code headless overlay mode (optional — auto-detected from PATH, ~/.local/bin, etc.)
# CLAUDE_BIN=/path/to/claude

# Codex CLI overlay provider for my-article sessions (optional — auto-detected from PATH and nvm)
# CODEX_BIN=/path/to/codex

# OpenAI Agents SDK provider
OPENAI_API_KEY=
OPENAI_AGENT_MODEL=gpt-5.4
OPENAI_AGENT_MAX_TURNS=30

# Local model for confidential review requests (OpenAI-compatible llama-server /v1 endpoint)
LOCAL_LLM_URL=http://100.122.169.13:8091/v1
LOCAL_LLM_MODEL=Qwen3.6
# LOCAL_LLM_API_KEY=

# Cloud fallback for ambiguous local review items.
# UI modes decide whether cloud receives paragraph-only context or full manuscript context.
# OUTSIDE_CLOUD_PROVIDER=claude
# OUTSIDE_CLOUD_PROVIDER=codex

# Data directory (use project-specific name to avoid conflicts with other projects)
REVIEWER_DATA_DIR=./data

# Semantic Scholar API (optional, increases rate limit)
SEMANTIC_SCHOLAR_API_KEY=

# OpenAlex polite-pool email (optional)
# OPENALEX_EMAIL=reviewer-agent@localhost

# Confidential review request timeouts (optional)
# OUTSIDE_OUTLINE_TIMEOUT_MS=480000
# OUTSIDE_DETAIL_ITEM_TIMEOUT_MS=360000

# App
NEXT_PUBLIC_APP_TITLE=reviewer-agent
