{
  "name": "researchdesk",
  "version": "0.1.4",
  "description": "Local-first AI prompt harnesses for scholarly article work.",
  "author": "ResearchDesk contributors",
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/junhewk/researchdesk.git"
  },
  "bugs": {
    "url": "https://github.com/junhewk/researchdesk/issues"
  },
  "main": "electron/main.cjs",
  "bin": {
    "researchdesk": "lib/cli.mjs",
    "researchdesk-mcp": "mcp/server.mjs",
    "reviewer-agent-mcp": "mcp/server.mjs"
  },
  "type": "module",
  "engines": {
    "node": "26.x"
  },
  "scripts": {
    "dev": "env -u TURBOPACK NODE_ENV=development PORT=${PORT:-3871} next dev --webpack --port ${PORT:-3871}",
    "desktop:dev": "ELECTRON_START_URL=http://localhost:${PORT:-3871} concurrently -k \"npm run dev\" \"wait-on http://localhost:${PORT:-3871} && electron .\"",
    "desktop:stage": "node scripts/stage-electron-app.mjs",
    "desktop:audit": "node scripts/audit-desktop-bundle.mjs",
    "desktop:postpack": "node scripts/fix-macos-app-xattrs.mjs",
    "desktop:pack": "npm run build && npm run desktop:stage && electron-builder --dir && npm run desktop:postpack && npm run desktop:audit",
    "desktop:dist": "npm run build && npm run desktop:stage && electron-builder && npm run desktop:postpack && npm run desktop:audit",
    "desktop:dist:win": "npm run build && npm run desktop:stage && electron-builder --win portable --x64 --publish never && npm run desktop:audit",
    "build": "next build",
    "start": "NODE_ENV=production PORT=${PORT:-3871} next start --port ${PORT:-3871}",
    "start:server": "NODE_ENV=production next start -H 127.0.0.1 -p ${PORT:-3871}",
    "mcp": "node mcp/server.mjs",
    "headless:bundle": "node scripts/build-headless-bundle.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "seed:demo": "tsx scripts/seed-diabetes-demo.ts",
    "seed:methods-demo": "tsx scripts/seed-methods-workbench-demo.ts"
  },
  "dependencies": {
    "@codemirror/commands": "^6.8.0",
    "@codemirror/lang-markdown": "^6.3.2",
    "@codemirror/search": "^6.5.10",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.5",
    "@langchain/core": "^1.1.42",
    "@langchain/deepseek": "^1.0.27",
    "@langchain/google-genai": "^2.1.31",
    "@langchain/ollama": "^1.2.7",
    "@langchain/openai": "^1.4.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex": "^0.142.5",
    "@openai/codex-sdk": "^0.142.5",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.1.14",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.3",
    "@types/papaparse": "^5.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff": "^9.0.0",
    "lucide-react": "^0.487.0",
    "mammoth": "^1.9.0",
    "mermaid": "^11.14.0",
    "nanoid": "^5.1.5",
    "next": "^16.0.0",
    "papaparse": "^5.5.4",
    "pdf-parse": "^1.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.2.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.4",
    "@types/diff": "^7.0.2",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "concurrently": "^9.1.2",
    "electron": "^42.3.3",
    "electron-builder": "^26.0.12",
    "eslint": "^9.25.1",
    "eslint-config-next": "^16.0.0",
    "tailwindcss": "^4.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.researchdesk.desktop",
    "productName": "ResearchDesk",
    "asar": true,
    "asarUnpack": [
      "node_modules/@openai/codex-*/vendor/**"
    ],
    "files": [
      "**/*",
      "!**/*.map",
      "!**/test/**",
      "!**/tests/**",
      "!**/__tests__/**",
      "!**/docs/**",
      "!**/examples/**",
      "!**/example/**",
      "!**/benchmarks/**",
      "!**/benchmark/**",
      "!src/**",
      "!data/**",
      "!scripts/**",
      "!bin/**",
      "!headless/**",
      "!mcp/**",
      "!test/**",
      "!*.md",
      "!package-lock.json",
      "!tsconfig.json",
      "!tsconfig.tsbuildinfo",
      "!eslint.config.mjs",
      "!postcss.config.mjs"
    ],
    "directories": {
      "app": ".release/desktop-app",
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "ResearchDesk-${version}-windows-${arch}.${ext}"
    }
  }
}
