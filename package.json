{
  "name": "reviewer-agent-desktop",
  "version": "0.1.0",
  "description": "Desktop academic peer-review and readiness workspace.",
  "author": "Reviewer Agent contributors",
  "private": false,
  "main": "electron/main.cjs",
  "type": "module",
  "engines": {
    "node": "26.x"
  },
  "scripts": {
    "dev": "env -u TURBOPACK NODE_ENV=development PORT=${PORT:-3871} next dev --webpack --port ${PORT:-3871}",
    "desktop:dev": "ELECTRON_START_URL=http://127.0.0.1:${PORT:-3871} concurrently -k \"npm run dev\" \"wait-on http://127.0.0.1:${PORT:-3871} && electron .\"",
    "desktop:pack": "npm run build && electron-builder --dir",
    "desktop:dist": "npm run build && electron-builder",
    "build": "NODE_ENV=production next build",
    "start": "NODE_ENV=production PORT=${PORT:-3871} next start --port ${PORT:-3871}",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "seed:demo": "tsx scripts/seed-diabetes-demo.ts",
    "seed:methods-demo": "tsx scripts/seed-methods-workbench-demo.ts",
    "repair:native": "npm rebuild better-sqlite3"
  },
  "dependencies": {
    "@codemirror/commands": "^6.8.0",
    "@codemirror/lang-markdown": "^6.3.2",
    "@codemirror/search": "^6.5.10",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.5",
    "@langchain/core": "^1.1.42",
    "@langchain/deepseek": "^1.0.27",
    "@langchain/google-genai": "^2.1.31",
    "@langchain/ollama": "^1.2.7",
    "@langchain/openai": "^1.4.5",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.1.14",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.3",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff": "^9.0.0",
    "lucide-react": "^0.487.0",
    "mammoth": "^1.9.0",
    "mermaid": "^11.14.0",
    "nanoid": "^5.1.5",
    "next": "^16.0.0",
    "pdf-parse": "^1.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.2.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^7.0.2",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "concurrently": "^9.1.2",
    "electron": "^42.3.3",
    "electron-builder": "^26.0.12",
    "eslint": "^9.25.1",
    "eslint-config-next": "^16.0.0",
    "tailwindcss": "^4.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.revieweragent.desktop",
    "productName": "Reviewer Agent",
    "asar": true,
    "files": [
      ".next/**",
      "electron/**",
      "next.config.ts",
      "package.json",
      "public/**",
      "src/**",
      "node_modules/**"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
